{
  "name": "lucian-code",
  "version": "0.1.0",
  "description": "Open Agentic Coding System",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "lucian": "src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "build:win": "bun build src/index.js --compile --target=bun-windows-x64 --outfile dist/lucian.exe",
    "build:linux": "bun build src/index.js --compile --target=bun-linux-x64 --outfile dist/lucian-linux",
    "build:macos": "bun build src/index.js --compile --target=bun-darwin-x64 --outfile dist/lucian-macos",
    "build:macos-arm": "bun build src/index.js --compile --target=bun-darwin-arm64 --outfile dist/lucian-macos-arm",
    "build:all": "npm run build:win && npm run build:linux && npm run build:macos && npm run build:macos-arm"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
